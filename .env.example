# Public URL of this provider. Used as the JWT `iss` and in the discovery doc.
# Must match what your GCP Workload Identity Federation pool expects.
OIDC_ISSUER=https://oidc.example.com

# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/oidc

# HTTP port (defaults to 8000).
PORT=8000

# Set to "True" to enable verbose behavior. Any other value = production mode.
DEBUG=False

# RSA key locations (relative to project root or absolute). Defaults shown.
PRIVATE_KEY_PATH=keys/private.pem
PUBLIC_KEY_PATH=keys/public.pem

# JWKS key id. Keep stable so GCP WIF keeps trusting the key.
OIDC_KEY_ID=f3d31c42-53bf-4cd9-8912-74df7be06bb7
